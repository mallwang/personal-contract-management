# Server
PORT=3000

# Database (defaults to data/contracts.db relative to the repo root)
# DATABASE_PATH=/absolute/path/to/contracts.db

# SMTP — required for email invitations
# AWS SES example: email-smtp.<region>.amazonaws.com
SMTP_HOST=email-smtp.eu-west-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your-ses-smtp-username
SMTP_PASSWORD=your-ses-smtp-password
SMTP_FROM=noreply@yourdomain.com

# Base URL used to build invitation links in emails
# In development the frontend runs on 5173; in production use your public domain
APP_URL=http://localhost:5173
